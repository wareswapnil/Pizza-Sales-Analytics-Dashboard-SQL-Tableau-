                <zone forceUpdate='true' h='29222' id='48' type-v2='text' w='15125' x='2500' y='30556'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontcolor='#8cd17d' fontname='Segoe UI Semibold' fontsize='11' underline='true'>HOURS</run>
                    <run fontalignment='1'>Æ&#10;</run>
                    <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Segoe UI Semibold' fontsize='10'>Peak orders are</run>
                    <run bold='true' fontalignment='1' fontcolor='#ff9da7' fontname='Segoe UI Semibold' fontsize='10'> between 12:00 PM and 1:00 PM</run>
                    <run bold='true' fontalignment='1' fontname='Segoe UI Semibold' fontsize='10'>, </run>
                    <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Segoe UI Semibold' fontsize='10'>and in evening,</run>
                    <run bold='true' fontalignment='1' fontcolor='#8cd17d' fontname='Segoe UI Semibold' fontsize='10'> from 4:00 PM to 7:00 PM</run>
                    <run bold='true' fontalignment='1' fontcolor='#8cd17d'>.</run>
                    <run fontalignment='1'>Æ&#10;&#10;</run>
                    <run bold='true' fontalignment='1' fontcolor='#a0cbe8' fontsize='11' underline='true'>WEEKS</run>
                    <run fontalignment='1'>Æ&#10;</run>
                    <run bold='true' fontalignment='1' fontcolor='#ff9da7' fontname='Segoe UI Semibold' fontsize='10'>Significant variations in weekly orders,</run>
                    <run bold='true' fontalignment='1' fontname='Segoe UI Semibold' fontsize='10'>Æ </run>
                    <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Segoe UI Semibold' fontsize='10'>with highest peak during the</run>
                    <run bold='true' fontalignment='1' fontcolor='#ff9da7' fontname='Segoe UI Semibold' fontsize='10'> 48th week</run>
                    <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Segoe UI Semibold' fontsize='10'> from the</run>
                    <run bold='true' fontalignment='1' fontname='Segoe UI Semibold' fontsize='10'>Æ </run>
                    <run bold='true' fontalignment='1' fontcolor='#b6992d' fontname='Segoe UI Semibold' fontsize='10'>month of Dec.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
